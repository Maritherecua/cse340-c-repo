<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <form action="/edit-category/<%= category.category_id %>" method="POST" id="edit-category-form">
            <div class="form-group">
                <label for="name">Category Name</label>
                <input type="text" id="name" name="name" value="<%= category.name %>" required maxlength="100" />
            </div>

            <button type="submit">Update Category</button>
        </form>

        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const form = document.getElementById('edit-category-form');
                const nameInput = document.getElementById('name');

                form.addEventListener('submit', (event) => {
                    const value = nameInput.value.trim();

                    if (!value) {
                        event.preventDefault();
                        nameInput.setCustomValidity('Category name is required');
                        nameInput.reportValidity();
                        return;
                    }

                    if (value.length > 100) {
                        event.preventDefault();
                        nameInput.setCustomValidity('Category name must be at most 100 characters');
                        nameInput.reportValidity();
                        return;
                    }

                    nameInput.setCustomValidity('');
                });
            });
        </script>
    </main>
    <%- include('partials/footer') %>