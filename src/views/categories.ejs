<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <ul>
            <% categories.forEach(category=> { %>
                <li>
                    <!-- Wrap the category name in a link pointing to the details page -->
                    <a href="/category/<%= category.category_id %>">
                    <%= category.name %>
                    </a>
                </li>
                <% }) %>
        </ul>
    </main>
    <%- include('partials/footer') %>