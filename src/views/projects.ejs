<!--Main project list view-->

<%- include('partials/header') %>
<main>
  <h1><%= title %></h1>
 <p><a href="/new-project">Add a New Service Project</a></p>
 
  <% if (!projects || projects.length === 0) { %>
    <p>No upcoming service projects found.</p>
  <% } else { %>
    <ul class="project-list">
      <% projects.forEach(project => { %>
        <% const formattedDate = new Date(project.date).toLocaleDateString('en-US', {
          month: 'short',
          day: 'numeric',
          year: 'numeric'
        }); %>
        <li class="project-tile">
          <a href="/project/<%= project.project_id %>" class="project-link">
            <strong><%= project.title %></strong>
            <span> — <%= formattedDate %></span>
          </a>
          <div>
            Organization:
            <a href="/organization/<%= project.organization_id %>">
              <%= project.organization_name %>
            </a>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } %>
</main>
<%- include('partials/footer') %>